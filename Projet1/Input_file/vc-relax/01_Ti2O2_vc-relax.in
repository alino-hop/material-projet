&CONTROL
  calculation   = 'vc-relax'
  restart_mode  = 'from_scratch'
  prefix        = 'Ti2O2'
  outdir        = './out_Ti2O2/'
  pseudo_dir    = './pseudo/'
  etot_conv_thr = 1.0d-7        ! Ry
  forc_conv_thr = 7.4d-4        ! 0.01 eV/Ang -> 7.4e-4 Ry/Bohr
  tprnfor       = .true.
  tstress       = .true.
  verbosity     = 'high'
/

&SYSTEMls

  ibrav         = 0
  nat           = 4             ! 2 Ti + 2 O
  ntyp          = 2
  ecutwfc       = 80.0          
  ecutrho       = 480.0         
  occupations   = 'smearing'
  smearing      = 'mp'
  degauss       = 0.02          ! Ry
   nspin                     = 2
   starting_magnetization(1) = 0.5   ! Ti
   starting_magnetization(2) = 0.0   ! O
  !
  ! --- SOC (faire relaxation sans SOC d'abord) ---
  ! noncolin  = .true.
  ! lspinorb  = .true.
/

&ELECTRONS
  conv_thr         = 1.0d-9    ! Ry
  mixing_beta      = 0.4
  mixing_mode      = 'plain'
  electron_maxstep = 300
/

&IONS
  ion_dynamics = 'bfgs'
/

&CELL
  cell_dynamics  = 'bfgs'
  press_conv_thr = 0.1          ! kbar
  cell_dofree    = '2Dxy'       ! relaxe a,b ; fixe c (vacuum)
/

ATOMIC_SPECIES
  Ti   47.867  Ti.upf
  O    15.999  O.upf
CELL_PARAMETERS {angstrom}
   2.96000   0.00000   0.00000
  -1.48000   2.56344   0.00000
   0.00000   0.00000   24.00000
   
ATOMIC_POSITIONS {crystal}
  Ti   0.333333   0.666667   0.500000
  Ti   0.666667   0.333333   0.500000
  O    0.333333   0.666667   0.447500
  O    0.666667   0.333333   0.552500

K_POINTS {automatic}
  23  23  1   0  0  0

